# Ticketmaster Discovery API (server only — no NEXT_PUBLIC_ prefix)
# Create an app at https://developer.ticketmaster.com/ and copy the API key.
TICKETMASTER_API_KEY=

# Google Maps JavaScript API — browser key (restrict by HTTP referrer in Google Cloud)
# https://console.cloud.google.com/ → APIs & Services → enable "Maps JavaScript API" → Credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
