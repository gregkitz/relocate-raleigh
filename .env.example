# Google Maps JavaScript API — browser key (restrict by HTTP referrer in Google Cloud)
# https://console.cloud.google.com/ → APIs & Services → enable "Maps JavaScript API" → Credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Anthropic API key — server only, used by scripts/update-events.mjs
# Generate at https://console.anthropic.com
# Also set as a GitHub secret named ANTHROPIC_API_KEY for the weekly cron.
ANTHROPIC_API_KEY=

# Resend API key — server only, used by Server Actions in src/lib/actions.ts
# Generate at https://resend.com → API Keys
RESEND_API_KEY=
